# Copy this file to .env and fill in your own values

# MongoDB connection string
# Local example: mongodb://127.0.0.1:27017/safaricom_sim_scanner
# Atlas example: mongodb+srv://<user>:<password>@cluster0.mongodb.net/safaricom_sim_scanner
MONGODB_URI=mongodb://127.0.0.1:27017/safaricom_sim_scanner

# Port the server runs on
PORT=3000

# Secret used to sign session cookies - set this to a long random string in production
SESSION_SECRET=change-this-to-a-long-random-string
